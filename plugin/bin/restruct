#!/bin/sh
# Auto-detect platform and run the correct restruct binary
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)        ARCH="x86_64" ;;
  aarch64|arm64) ARCH="arm64" ;;
esac
BINARY="${SCRIPT_DIR}/restruct-${OS}-${ARCH}"
if [ ! -x "$BINARY" ]; then
  echo "restruct: no binary for ${OS}-${ARCH}" >&2
  exit 1
fi

# Run binary and propagate exit code.
# Exit 0: success. Exit 1: cobra command error (expected). Exit 2: hook block decision.
# Only flag truly unexpected codes (>= 3 or signals like 139).
"$BINARY" "$@"
rc=$?
if [ "$rc" -gt 2 ]; then
  echo "restruct: unexpected exit code $rc from $BINARY $*" >&2
fi
exit $rc
