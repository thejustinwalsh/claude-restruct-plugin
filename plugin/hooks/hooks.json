{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/restruct refine"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -x \"${CLAUDE_PLUGIN_ROOT}/bin/restruct\" || echo 'restruct: binary not found — plugin may not be built for this platform' >&2"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/restruct model load > /dev/null 2>&1 &"
          }
        ]
      }
    ]
  }
}
